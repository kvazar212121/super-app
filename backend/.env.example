APP_NAME=super-app-api
DEBUG=true
API_V1_PREFIX=/api/v1

# PostgreSQL (Docker: host 5433 -> konteyner 5432)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/superapp

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT (productionda kuchli random qiymat)
SECRET_KEY=o-zgartiring-production-uchun
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (Flutter veb / mobil domenlar)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://192.168.0.252:8080
